VITE_VAPI_PUBLIC_KEY=your_vapi_public_key
VITE_VAPI_ASSISTANT_ID=your_vapi_assistant_id
# Leave unset for local dev: Vite proxies /api → http://127.0.0.1:8000 (no CORS issues).
# Set full URL only if the UI is hosted separately from the API (production / ngrok).
