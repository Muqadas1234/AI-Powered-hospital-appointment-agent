# User + password must match your PostgreSQL install. Create DB first: CREATE DATABASE appointment_agent;
DATABASE_URL=postgresql+psycopg2://postgres:admin@localhost:5432/appointment_agent
APP_HOST=127.0.0.1
APP_PORT=8000
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_FILE=google-service-account.json
TOOL_API_KEY=replace_with_strong_random_token
JWT_SECRET_KEY=replace_with_very_strong_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_ROLE=admin
ADMIN_AUTH_DISABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
# WhatsApp reminders (Twilio WhatsApp sandbox/number)
WHATSAPP_REMINDER_ENABLED=true
# Example: whatsapp:+14155238886 (Twilio sandbox) or your approved WhatsApp sender
TWILIO_WHATSAPP_FROM=
# Timezone for appointment times + reminder scheduling (IANA, e.g. Asia/Karachi)
APP_TIMEZONE=Asia/Karachi
# Reminder flow:
# - SMS reminder at T-24h
# - WhatsApp second reminder at T-24h
REMINDER_SMS_LEAD_MINUTES=1440
REMINDER_WHATSAPP_LEAD_MINUTES=1440
# Public API base URL for Twilio Voice webhooks
# Example local via tunnel: https://your-ngrok-url.ngrok-free.dev
PUBLIC_BASE_URL=
# Reminder worker polling interval (APScheduler every N minutes)
REMINDER_JOB_ENABLED=true
REMINDER_JOB_INTERVAL_MINUTES=5
NOTIFICATION_RETRY_ENABLED=true
NOTIFICATION_RETRY_INTERVAL_MINUTES=5
NOTIFICATION_RETRY_MAX_ATTEMPTS=2
NOTIFICATION_RETRY_DELAY_MINUTES=2
NOTIFICATION_RETRY_BACKOFF_MULTIPLIER=1.5
NOTIFICATION_RETRY_BATCH_SIZE=20
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
VAPI_PRIVATE_API_KEY=c5d7a7b2-4be0-4a2d-9b5d-2b29f9818d78
VAPI_ASSISTANT_ID=17d1ccdd-60a5-4fbe-a1f6-9958d577d3b4
VAPI_NGROK_URL=https://appendix-footbath-unvocal.ngrok-free.dev
# Optional — opening line when call starts (default is Assalamualaikum greeting if unset)
# VAPI_FIRST_MESSAGE=Assalamualaikum. Welcome — how may I help you today?
# Optional — more natural voice (run: python scripts/sync_vapi.py after setting)
# VAPI_VOICE_PROVIDER=11labs
# VAPI_VOICE_ID=Rachel
